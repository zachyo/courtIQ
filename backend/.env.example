# PostgreSQL connection string (Railway provides this as DATABASE_URL automatically)
DATABASE_URL="postgresql://courtiq:courtiq@localhost:5432/courtiq_dev"

# Secret used to sign manager JWTs — generate with: openssl rand -hex 32
JWT_SECRET="change-me"

# Port the API listens on (Railway injects PORT automatically)
PORT=3000

# Allowed origin for the web frontend, e.g. https://courtiq.app or http://localhost:5173
CORS_ORIGIN="*"
